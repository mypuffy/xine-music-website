# Xine Music Environment Variables

# Database Configuration
DB_USER=xine_music_user
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@database:5432/xine_music

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure

# API Configuration
API_PORT=3001
ADMIN_PORT=3002

# Email Configuration (for contact forms)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@xine-music.de
SMTP_PASSWORD=your_smtp_password

# External Services
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# File Upload Configuration
UPLOAD_MAX_SIZE=10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,mp3,wav,flac

# Security
CORS_ORIGIN=https://xine-music.de
SESSION_SECRET=your_session_secret_here

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn_here